<?xml version="1.0" encoding="UTF-8"?>
<schemalist gettext-domain="museic">
	<schema id="io.github.drvonmiau.Museic" path="/io/github/drvonmiau/Museic/">
		<key name="theme" type="s">
			<choices>
				<choice value="light"/>
				<choice value="dark"/>
				<choice value="system"/>
			</choices>
			<default>'system'</default>
			<summary>Color theme</summary>
			<description>Whether to use the light theme, the dark theme, or follow the system preference.</description>
		</key>
		<key name="window-width" type="i">
			<default>1180</default>
			<summary>Window width</summary>
		</key>
		<key name="window-height" type="i">
			<default>740</default>
			<summary>Window height</summary>
		</key>
		<key name="window-maximized" type="b">
			<default>false</default>
			<summary>Window maximized</summary>
		</key>
		<key name="volume" type="d">
			<default>0.7</default>
			<summary>Playback volume</summary>
		</key>
		<key name="shuffle" type="b">
			<default>false</default>
			<summary>Shuffle playback</summary>
		</key>
		<key name="repeat" type="b">
			<default>false</default>
			<summary>Repeat the queue</summary>
		</key>
		<key name="last-tab" type="s">
			<default>'artists'</default>
			<summary>Last active library tab</summary>
		</key>
		<key name="queue" type="s">
			<default>''</default>
			<summary>Saved play queue</summary>
			<description>JSON with the current track id and upcoming track ids, restored on startup.</description>
		</key>
		<key name="watch-folders" type="b">
			<default>false</default>
			<summary>Watch music folders</summary>
			<description>Automatically rescan the library when files change in the music folders.</description>
		</key>
		<key name="sort-artists" type="s">
			<default>'name'</default>
			<summary>Artists tab sort order</summary>
		</key>
		<key name="sort-albums" type="s">
			<default>'artist'</default>
			<summary>Albums tab sort order</summary>
		</key>
		<key name="sort-tracks" type="s">
			<default>'title'</default>
			<summary>Tracks/Favourites sort order</summary>
		</key>
		<key name="notify-on-track-change" type="b">
			<default>true</default>
			<summary>Track change notifications</summary>
			<description>Show a desktop notification when the track changes while the window is unfocused.</description>
		</key>
	</schema>
</schemalist>
